{
  "version": "1.0",
  "siteId": "qsr-uk",
  "overlays": {
    "/menu": {
      "provider": "menu-provider",
      "url": "https://dynamic.yourbrand.com/menu-provider",
      "cacheTtl": 300
    },
    "/stores": {
      "provider": "store-provider",
      "url": "https://dynamic.yourbrand.com/store-provider",
      "cacheTtl": 600
    },
    "/rewards": {
      "provider": "rewards-provider",
      "url": "https://dynamic.yourbrand.com/rewards-provider",
      "cacheTtl": 120
    },
    "/account": {
      "provider": "user-provider",
      "url": "https://dynamic.yourbrand.com/user-provider",
      "cacheTtl": 60
    },
    "/rewards-feed": {
      "provider": "bff-proxy",
      "url": "https://dynamic.yourbrand.com/bff-proxy",
      "cacheTtl": 60
    }
  },
  "auth": {
    "clientId": "{IMS_CLIENT_ID}",
    "scope": "openid,AdobeID,read_organizations"
  },
  "sso": {
    "enabled": false,
    "provider": "azure",
    "logLevel": "info",
    "publicPaths": ["/", "/login", "/callback", "/logout", "/menu", "/stores"],
    "callbackPath": "/callback",
    "logoutPath": "/logout",
    "azure": {
      "tenantId": "{AZURE_TENANT_ID}",
      "clientId": "{AZURE_CLIENT_ID}",
      "redirectUri": "https://main--qsr-uk--org.aem.live/callback",
      "scope": "openid profile email",
      "postLogoutRedirectUri": "https://main--qsr-uk--org.aem.live"
    },
    "ims": {
      "clientId": "{IMS_CLIENT_ID}",
      "redirectUri": "https://main--qsr-uk--org.aem.live/callback",
      "scope": "openid,AdobeID,read_organizations",
      "postLogoutRedirectUri": "https://main--qsr-uk--org.aem.live"
    }
  },
  "market": "uk",
  "edsHost": "main--qsr-uk--org.aem.live"
}
